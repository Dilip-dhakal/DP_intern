// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ReminderPriority {
  LOW
  MEDIUM
  HIGH
}

enum ReminderStatus {
  PENDING
  COMPLETED
}

enum ReminderRepeat {
  NONE
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum AuditEntityType {
  INCOME
  EXPENSE
  NOTE
  REMINDER
  AUTH
}

enum AuditAction {..........
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CHEQUE
  ESEWA
  KHALTI
  OTHER
}

enum AttachmentEntityType {
  INCOME
  EXPENSE
  REMINDER
}

enum StorageProvider {
  CLOUDINARY
  LOCAL
}

enum RoleName {
  ACCOUNTANT
  ADMIN
  SUPER_ADMIN
}


model User {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String

  oauthProvider String?
  oauthId       String?

  isActive Boolean @default(true)

  createdIncomes Income[] @relation("IncomeCreatedBy")
  updatedIncomes Income[] @relation("IncomeUpdatedBy")
  createdExpenses Expense[] @relation("ExpenseCreatedBy")
updatedExpenses Expense[] @relation("ExpenseUpdatedBy")
 userRoles UserRole[]
  auditLogs AuditLog[]
  attachments Attachment[]
  createdNotes Note[] @relation("NoteCreatedBy")
  deletedNotes Note[] @relation("NoteDeletedBy")
  updatedNotes Note[] @relation("NoteUpdatedBy")
  remindersCreated Reminder[] @relation("ReminderCreatedBy")
deletedReminders Reminder[] @relation("ReminderDeletedBy")


  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model IncomeCategory {
  id          String   @id @default(uuid())
  name        String
  description String?
  isActive    Boolean  @default(true)
  incomes     Income[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model ExpenseCategory {
  id          String  @id @default(uuid())
  name        String
  description String?

  isActive Boolean   @default(true)
  expenses Expense[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Income {
  id               String         @id @default(uuid())
  transactionDate  DateTime
  amount           Decimal        @db.Decimal(15, 2)
  incomeCategoryId String
  incomeCategory   IncomeCategory @relation(fields: [incomeCategoryId], references: [id])
  incomeSource     String?
  clientName       String?
  paymentMethod    PaymentMethod
  referenceNumber  String?
  invoiceNumber    String?
  description      String?

  createdById String
  createdBy   User      @relation("IncomeCreatedBy", fields: [createdById], references: [id])
  updatedById String?
  updatedBy   User?     @relation("IncomeUpdatedBy", fields: [updatedById], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
}

model Expense {
  id String @id @default(uuid())

  transactionDate DateTime
  amount          Decimal @db.Decimal(15,2)
  vendorName        String?
  expenseCategoryId String

  expenseCategory ExpenseCategory @relation(fields: [expenseCategoryId],references: [id])

  paymentMethod   PaymentMethod
  referenceNumber String?
  invoiceNumber   String?
  description     String?

  createdById String

  createdBy User @relation("ExpenseCreatedBy",fields: [createdById],references: [id])

  updatedById String?

  updatedBy User? @relation("ExpenseUpdatedBy",fields: [updatedById],references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
}

model AuditLog {
  id         String          @id @default(uuid())
  userId     String?
  user       User?           @relation(fields: [userId], references: [id])
  entityType AuditEntityType
  entityId   String?
  action     AuditAction
  oldValues  Json?
  newValues  Json?
  ipAddress  String?

  createdAt DateTime @default(now())
}


model Attachment {
  id String @id @default(uuid())

  entityType AttachmentEntityType
  entityId String

  fileName String
  fileSize Int
  mimeType String

  storageKey String
  storageUrl String

  provider StorageProvider

  uploadedById String
  uploadedBy User @relation(fields: [uploadedById], references: [id])

  createdAt DateTime @default(now())
  deletedAt DateTime?
}

model Role {
  id          String   @id @default(uuid())
  name        RoleName @unique
  description String?

  userRoles UserRole[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}



model UserRole {
  id String @id @default(uuid())

  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, roleId])
}

model Note {
  id String @id @default(uuid())

  title String
  description String

  colorLabel String?

  isPinned Boolean @default(false)
  isArchived Boolean @default(false)

  createdById String
  createdBy User @relation("NoteCreatedBy", fields: [createdById], references: [id])
  updatedById String?
updatedBy User? @relation("NoteUpdatedBy", fields: [updatedById], references: [id])
  deletedById String?
  deletedBy User? @relation("NoteDeletedBy", fields: [deletedById], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
}

model Reminder {
  id String @id @default(uuid())

  title String
  description String?

  reminderDate DateTime
  reminderTime String?

  priority ReminderPriority
  status ReminderStatus @default(PENDING)
  repeat ReminderRepeat @default(NONE)

  createdById String
  createdBy User @relation("ReminderCreatedBy",fields:[createdById],references:[id])

  deletedById String?
  deletedBy User? @relation("ReminderDeletedBy",fields:[deletedById],references:[id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([status])
  @@index([priority])
  @@index([reminderDate])
}